<turbo-frame id="product_detail">
  <% if @product %>
    <div class="card">
      <div class="card-header">
        <strong><%= @product[:name] %></strong>
      </div>
      <ul class="list-group list-group-flush">
        <li class="list-group-item">Price: $<%= @product[:price] %></li>
        <li class="list-group-item">Stock: <%= @product[:stock] %> units</li>
        <li class="list-group-item">Made in: <%= @product[:made_in] %></li>
        <li class="list-group-item">Seller: <%= link_to(@product[:seller], seller_path(@product[:seller]), data: { turbo_frame: "seller_detail" }) %> </li>
      </ul>
    </div>
  <% else %>
    <div class="alert alert-warning">Product not found.</div>
  <% end %>
</turbo-frame>
