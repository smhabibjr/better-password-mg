<h4 class="text-center mb-4">Forgot your password?</h4>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="form-floating mb-3">
  <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "name@example.com" %>
    <%= f.label :email %>
  </div>

  <div class="actions mb-3">
    <%= f.submit "Send me reset password instructions", class: "btn btn-primary w-100" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
